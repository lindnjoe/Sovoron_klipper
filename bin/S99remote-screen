#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-or-later
#
# S99remote-screen — start the Snapmaker U1 "Remote Screen" (fb-http -> Mainsail)
# at boot, INDEPENDENTLY of HelixScreen (whose updates overwrite its own hook).
#
# Daemonized the same way as the U1's openrfid init (start-stop-daemon -S -b -m),
# the proven long-lived-daemon pattern on this device. Every decision is written
# to a persistent boot log so a failed boot is diagnosable (rcS gives init scripts
# no console we can read after the fact).
#
# Install (run on the U1 as root):
#   cp bin/S99remote-screen /etc/init.d/S99remote-screen
#   chmod +x /etc/init.d/S99remote-screen
#   /etc/init.d/S99remote-screen start

PIDFILE=/var/run/remote-screen.pid
BIN=/usr/local/bin/fb-http.py
LOG=/tmp/fb-http.log
BOOTLOG=/userdata/remote-screen.boot.log
PORT=8092

_log() { echo "[$(date '+%H:%M:%S' 2>/dev/null)] $*" >> "$BOOTLOG" 2>/dev/null; }

start() {
    _log "start() invoked (pid $$, arg=$1)"
    [ -f "$BIN" ] || { _log "BIN missing: $BIN"; echo "remote-screen: $BIN missing"; return; }

    # Honor the Remote Screen toggle. Try the boot-reliable /oem path first
    # (what openrfid uses), then /home/lava; fail OPEN if neither is readable.
    CFG=""
    for c in /oem/printer_data/config/extended/extended2.cfg \
             /home/lava/printer_data/config/extended/extended2.cfg; do
        [ -f "$c" ] && { CFG="$c"; break; }
    done
    if [ -n "$CFG" ] && [ -x /usr/local/bin/extended-config.py ]; then
        RS=$(/usr/local/bin/extended-config.py get "$CFG" web remote_screen false 2>/dev/null)
        _log "toggle: CFG=$CFG remote_screen=$RS"
        case "$RS" in
            [Tt][Rr][Uu][Ee]) ;;
            *) _log "disabled; not starting"; echo "remote-screen: disabled ($RS)"; return ;;
        esac
    else
        _log "config not found (CFG='$CFG'); fail-open"
    fi

    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        _log "already running (pid $(cat "$PIDFILE"))"
        echo "remote-screen: already running"
        return 0
    fi

    _log "launching fb-http via start-stop-daemon"
    printf "Starting Remote Screen: "
    start-stop-daemon -S -b -m -p "$PIDFILE" -x /bin/sh -- -c \
        "exec /usr/bin/python3 $BIN --bind 127.0.0.1 --port $PORT --backend drm --drm-device /dev/dri/card0 --drm-wait 60 --html-dir /usr/local/share/fb-http/html >$LOG 2>&1"
    _log "start-stop-daemon returned rc=$?"
    echo "OK"
}

stop() {
    printf "Stopping Remote Screen: "
    if [ -f "$PIDFILE" ]; then
        start-stop-daemon -K -p "$PIDFILE" -s TERM
        rm -f "$PIDFILE"
        echo "OK"
    else
        pkill -f "$BIN" 2>/dev/null
        echo "OK"
    fi
}

case "$1" in
    start)          start ;;
    stop)           stop ;;
    restart|reload) stop; sleep 1; start ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            echo "remote-screen: running (pid $(cat "$PIDFILE"))"
        else
            pgrep -af "$BIN" || { echo "remote-screen: not running"; exit 1; }
        fi
        ;;
    *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac

exit $?

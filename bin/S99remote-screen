#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-or-later
#
# S99remote-screen — start the Snapmaker U1 "Remote Screen" (fb-http -> Mainsail)
# at boot, INDEPENDENTLY of HelixScreen.
#
# Why this instead of patching HelixScreen's hooks.sh: HelixScreen regenerates /
# overwrites its platform hook on every update, which silently wipes any patch we
# add there and breaks the remote display. This init script lives outside
# HelixScreen's tree, so HelixScreen updates can't touch it.
#
# Daemonization: this mirrors the U1's own openrfid init script, which is the
# proven way to launch a long-lived daemon from rcS on this device. A hand-rolled
# `setsid &` / `worker &` did NOT survive boot here (it worked from an interactive
# shell but got reaped at boot), whereas `start-stop-daemon -S -b -m` does. We
# wrap fb-http in `sh -c 'exec ... > log'` so we keep a log while the pidfile
# still tracks the real fb-http PID (exec preserves it).
#
# Config: read the Remote Screen toggle from the same place openrfid does
# (/oem/printer_data), which is reliably mounted at boot; fall back to the
# /home/lava path; fail OPEN (start anyway) if neither is readable.
#
# Install (run on the U1 as root):
#   cp bin/S99remote-screen /etc/init.d/S99remote-screen
#   chmod +x /etc/init.d/S99remote-screen
#   /etc/init.d/S99remote-screen start

PIDFILE=/var/run/remote-screen.pid
BIN=/usr/local/bin/fb-http.py
LOG=/tmp/fb-http.log
PORT=8092

start() {
    [ -f "$BIN" ] || { echo "remote-screen: $BIN missing"; return; }

    # Honor the Remote Screen toggle. Try the boot-reliable /oem path first
    # (what openrfid uses), then the /home/lava path; fail open if neither.
    CFG=""
    for c in /oem/printer_data/config/extended/extended2.cfg \
             /home/lava/printer_data/config/extended/extended2.cfg; do
        [ -f "$c" ] && { CFG="$c"; break; }
    done
    if [ -n "$CFG" ] && [ -x /usr/local/bin/extended-config.py ]; then
        RS=$(/usr/local/bin/extended-config.py get "$CFG" web remote_screen false 2>/dev/null)
        case "$RS" in
            [Tt][Rr][Uu][Ee]) ;;
            *) echo "remote-screen: disabled (web.remote_screen=$RS), not starting."; return ;;
        esac
    else
        echo "remote-screen: config not found, starting anyway (fail-open)."
    fi

    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "remote-screen: already running"
        return 0
    fi

    printf "Starting Remote Screen: "
    start-stop-daemon -S -b -m \
        -p "$PIDFILE" \
        -x /bin/sh -- -c \
        "exec /usr/bin/python3 $BIN --bind 127.0.0.1 --port $PORT \
            --backend drm --drm-device /dev/dri/card0 --drm-wait 60 \
            --html-dir /usr/local/share/fb-http/html >$LOG 2>&1"
    echo "OK"
}

stop() {
    printf "Stopping Remote Screen: "
    if [ -f "$PIDFILE" ]; then
        start-stop-daemon -K -p "$PIDFILE" -s TERM
        rm -f "$PIDFILE"
        echo "OK"
    else
        pkill -f "$BIN" 2>/dev/null
        echo "OK"
    fi
}

case "$1" in
    start)        start ;;
    stop)         stop ;;
    restart|reload) stop; sleep 1; start ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            echo "remote-screen: running (pid $(cat "$PIDFILE"))"
        else
            pgrep -af "$BIN" || { echo "remote-screen: not running"; exit 1; }
        fi
        ;;
    *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac

exit $?

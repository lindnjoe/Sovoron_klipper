#!/bin/sh
# SPDX-License-Identifier: GPL-3.0-or-later
#
# S99remote-screen — start the Snapmaker U1 "Remote Screen" (fb-http -> Mainsail)
# at boot, INDEPENDENTLY of HelixScreen.
#
# Why this instead of patching HelixScreen's hooks.sh: HelixScreen regenerates /
# overwrites its platform hook on every update, which silently wipes any patch we
# add there and breaks the remote display until it's re-applied. This init script
# lives outside HelixScreen's tree, so HelixScreen updates can't touch it.
#
# Daemonization: rcS runs each init script with `$i start` and waits for it to
# return. A plain `worker &` orphan does NOT survive that at boot (it gets reaped
# before it does anything — which is why a manual start worked but boot didn't).
# So we re-exec ourselves under setsid into a NEW session (a real detached
# daemon, like openrfid does) which survives rcS finishing this script.
#
# The worker waits for printer_data (config) to be available, honors the Remote
# Screen toggle (fail-open if the config never appears), then exec's fb-http.
# fb-http's --drm-wait tolerates starting before helix has an active CRTC.
#
# Install (run on the U1 as root):
#   cp bin/S99remote-screen /etc/init.d/S99remote-screen
#   chmod +x /etc/init.d/S99remote-screen
#   /etc/init.d/S99remote-screen start

BIN=/usr/local/bin/fb-http.py
CFG=/home/lava/printer_data/config/extended/extended2.cfg
PORT=8092
LOG=/tmp/fb-http.log
# Persistent (survives reboot, unlike /tmp tmpfs) so a failed boot is diagnosable.
BOOTLOG=/userdata/remote-screen.boot.log

_log() { echo "[$(date '+%H:%M:%S' 2>/dev/null)] $*" >> "$BOOTLOG" 2>/dev/null; }

worker() {
    _log "worker start (pid $$)"
    [ -f "$BIN" ] || { _log "fb-http.py missing at $BIN"; return; }

    # Config should already be mounted at S99, but tolerate a slow mount: wait
    # up to 60s for it. Fail OPEN (start anyway) if it never appears.
    i=0
    while [ ! -f "$CFG" ] && [ "$i" -lt 60 ]; do
        sleep 1
        i=$((i + 1))
    done
    if [ -f "$CFG" ] && [ -x /usr/local/bin/extended-config.py ]; then
        rs=$(/usr/local/bin/extended-config.py get "$CFG" web remote_screen false 2>/dev/null)
        _log "remote_screen=$rs (config ready after ${i}s)"
        case "$rs" in
            [Tt][Rr][Uu][Ee]) ;;
            *) _log "disabled; not starting"; return ;;
        esac
    else
        _log "config not found after ${i}s; starting anyway (fail-open)"
    fi

    if pgrep -f "$BIN" >/dev/null 2>&1; then
        _log "already running"
        return
    fi
    _log "exec fb-http on :$PORT (DRM)"
    # exec: become the fb-http process (this shell is already the detached
    # session leader from setsid), so the daemon outlives boot.
    exec /usr/bin/python3 "$BIN" \
        --bind 127.0.0.1 --port "$PORT" \
        --backend drm --drm-device /dev/dri/card0 --drm-wait 60 \
        --html-dir /usr/local/share/fb-http/html >"$LOG" 2>&1
}

spawn() {
    # Detach into a new session so the worker survives rcS finishing this script.
    if command -v setsid >/dev/null 2>&1; then
        setsid "$0" __worker </dev/null >/dev/null 2>&1 &
    else
        # Fallback: double-fork via subshell (less bulletproof than setsid).
        ( "$0" __worker </dev/null >/dev/null 2>&1 & )
    fi
}

case "$1" in
    start)    spawn ;;
    __worker) worker ;;
    stop)     pkill -f "$BIN" 2>/dev/null; echo "remote-screen: stopped" ;;
    restart)  pkill -f "$BIN" 2>/dev/null; sleep 1; spawn ;;
    status)   pgrep -af "$BIN" || { echo "remote-screen: not running"; exit 1; } ;;
    *)        echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
